.venv/
venv/
env/
.conda/

# ── Dataset — raw .bin files (~1.6 GB), not versioned ────────────────────────
# Folder structure is tracked (with .gitkeep); place your .bin files inside.
original_dataset/**/*.bin

# ── Processed data caches — reproducible by running 00_setup.ipynb ───────────
# Folder structure is tracked (with .gitkeep); caches are regenerated by 00_setup.ipynb.
processed_data/**/*.h5

# ── Model checkpoints — reproducible by running notebooks 02 and 04 ──────────
binary_pla/results/
*.pt
*.pth
*.ckpt

# ── LaTeX ─────────────────────────────────────────────────────────────────────
# Compiled PDF is not tracked; figures (report/figures/*.pdf) ARE tracked
# since they are the visual outputs of the experiments.
report/*.aux
report/*.bbl
report/*.bcf
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
report/*.run.xml
report/*.synctex.gz
report/*.toc
report/*.nav
report/*.snm
report/*.vrb

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
